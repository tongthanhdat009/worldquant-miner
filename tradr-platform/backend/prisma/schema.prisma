// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Profile
  level         Int      @default(1)
  xp            Int      @default(0)
  totalXp       Int      @default(0)
  eloRating    Int      @default(1000)
  tier          String   @default("Bronze")

  // Relationships
  matches       MatchPlayer[]
  achievements  UserAchievement[]
  positions     Position[]
  orders        Order[]
  stats         UserStats?

  @@map("users")
}

model UserStats {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  totalMatches    Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  draws           Int      @default(0)
  winRate         Float    @default(0.0)
  
  totalTrades     Int      @default(0)
  profitableTrades Int     @default(0)
  totalProfit     Float    @default(0.0)
  
  averageApm      Float    @default(0.0)
  highestApm      Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_stats")
}

model Match {
  id            String   @id @default(uuid())
  mode          String   // 'pvp_1v1', 'pvp_battle_royale', 'pve_ai_challenge', 'pve_campaign', 'ranked_matchmaking'
  status        String   @default("waiting") // 'waiting', 'running', 'finished', 'cancelled'
  
  initialCapital Float   @default(10000.0)
  duration       Int     // minutes
  startedAt      DateTime?
  endedAt        DateTime?
  
  marketSymbol   String?
  marketData     Json?   // Store market simulation data
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  players        MatchPlayer[]
  positions      Position[]
  orders         Order[]

  @@map("matches")
}

model MatchPlayer {
  id            String   @id @default(uuid())
  matchId       String
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  isAi          Boolean  @default(false)
  aiDifficulty  String?  // 'easy', 'medium', 'hard'
  
  portfolioValue Float   @default(0.0)
  cash          Float    @default(0.0)
  totalValue    Float    @default(0.0)
  
  trades        Int      @default(0)
  apm           Float    @default(0.0)
  accuracy      Float    @default(0.0)
  
  status        String   @default("active") // 'active', 'eliminated', 'finished'
  rank          Int?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("match_players")
}

model Position {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  matchId       String?
  match         Match?   @relation(fields: [matchId], references: [id], onDelete: SetNull)
  
  symbol        String
  side          String   // 'BUY', 'SELL'
  quantity      Float
  entryPrice    Float
  currentPrice  Float
  unrealizedPnl Float   @default(0.0)
  
  stopLoss      Float?
  takeProfit    Float?
  
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  
  @@map("positions")
}

model Order {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  matchId       String?
  match         Match?   @relation(fields: [matchId], references: [id], onDelete: SetNull)
  
  symbol        String
  side          String   // 'BUY', 'SELL'
  type          String   // 'MARKET', 'LIMIT', 'STOP'
  quantity      Float
  price         Float?
  
  status        String   @default("pending") // 'pending', 'filled', 'cancelled', 'rejected'
  
  filledQuantity Float   @default(0.0)
  averagePrice   Float?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  filledAt      DateTime?

  @@map("orders")
}

model Achievement {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String
  xpReward      Int      @default(0)
  icon          String?
  
  createdAt     DateTime @default(now())

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  achievementId String
  achievement    Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  unlockedAt    DateTime @default(now())

  @@unique([userId, achievementId])
  @@map("user_achievements")
}
